# NeuroScan AI Environment Variables
# Copy this file to .env.local and update with your actual values

# Backend API Configuration
# Default: http://localhost:8000/api/v1
VITE_API_BASE_URL=http://localhost:8000/api/v1

# Application Metadata
# VITE_APP_TITLE=NeuroScan AI
# VITE_APP_VERSION=1.0.0

# Features (toggle features for testing)
# VITE_ENABLE_MOCK_DATA=true
# VITE_ENABLE_API_LOGGING=false

# External Services (if applicable)
# VITE_SENTRY_DSN=
# VITE_ANALYTICS_ID=

# Note:
# - All variables prefixed with VITE_ are exposed to the client-side
# - Do NOT include sensitive data (API keys, secrets, passwords)
# - Use server-side environment variables for sensitive data
# - Restart the dev server after changing variables
